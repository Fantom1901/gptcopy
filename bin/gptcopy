#!/usr/bin/env bash

# Список того, что мы ненавидим
IGNORE_LIST=(
    node_modules venv .git .idea .vscode __pycache__
    target dist build .next .astro .cache
    package-lock.json pnpm-lock.yaml yarn.lock
)

# Строка для tree
TREE_IGNORE="node_modules|venv|.git|.idea|.vscode|__pycache__|target|dist|build|.next|.astro|.cache|package-lock\.json|pnpm-lock\.yaml|yarn\.lock"

# Цвета для справки
CYAN='\e[1;36m'
GREEN='\e[1;32m'
YELLOW='\e[1;33m'
BLUE='\e[1;34m'
NC='\e[0m'

show_help() {
    echo -e "${BLUE}🚀 gptcopy${NC} — Подготовка контекста проекта для LLM"
    echo -e ""
    echo -e "${YELLOW}ИСПОЛЬЗОВАНИЕ:${NC}"
    echo -e "  gptcopy [путь] [флаги]"
    echo -e ""
    echo -e "${YELLOW}ФЛАГИ:${NC}"
    echo -e "  ${GREEN}-c, --changed${NC}    Копировать только изменённые файлы (нужен Git)"
    echo -e "  ${GREEN}-m, --minify${NC}     Удалить пустые строки из кода (экономия токенов)"
    echo -e "  ${GREEN}-h, --help${NC}       Показать эту красивую справку"
    echo -e ""
    echo -e "${YELLOW}ПРИМЕРЫ:${NC}"
    echo -e "  gptcopy .             # Весь текущий проект"
    echo -e "  gptcopy src/ -m       # Только папка src с минификацией"
    echo -e "  gptcopy -c            # Только то, что ты накодил (git diff)"
    echo -e ""
    echo -e "${BLUE}📂 ИГНОРИРУЕТСЯ ПО УМОЛЧАНИЮ:${NC}"
    echo -e "  node_modules, .git, venv, package-lock.json и др."
    exit 0
}

get_copy_cmd() {
    local cmd=""
    if [[ "$TERM" == "xterm-kitty" ]] && command -v kitten >/dev/null 2>&1; then
        cmd="kitten clipboard"
    elif command -v wl-copy >/dev/null 2>&1; then
        cmd="wl-copy"
    elif command -v xclip >/dev/null 2>&1; then
        cmd="xclip -selection clipboard"
    fi

    if [[ -n "$cmd" ]]; then
        echo "$cmd"
    else
        echo -e "\e[1;33m[!]\e[0m Утилита для копирования не найдена. Вывод в терминал." >&2
        echo "cat"
    fi
}

ONLY_CHANGED=0
MINIFY=0
TARGETS=()

# Парсинг аргументов
for arg in "$@"; do
    case $arg in
        -c|--changed) ONLY_CHANGED=1 ;;
        -m|--minify)  MINIFY=1 ;;
        -h|--help)    show_help ;;
        *)            TARGETS+=("$arg") ;;
    esac
done

[[ ${#TARGETS[@]} -eq 0 ]] && TARGETS+=(".")
COPY_CMD=$(get_copy_cmd)

FIND_IGNORE_ARGS=()
for item in "${IGNORE_LIST[@]}"; do
    if [ ${#FIND_IGNORE_ARGS[@]} -gt 0 ]; then FIND_IGNORE_ARGS+=("-o"); fi
    FIND_IGNORE_ARGS+=("-name" "$item" "-o" "-path" "*/$item/*")
done

{
    echo "=== PROJECT STRUCTURE ==="
    if [ "$ONLY_CHANGED" -eq 1 ]; then
        git status -s 2>/dev/null || echo "Git не инициализирован."
    else
        if command -v tree >/dev/null 2>&1; then
            tree -a -I "$TREE_IGNORE" "${TARGETS[0]}"
        else
            find "${TARGETS[0]}" -maxdepth 2 \( \( "${FIND_IGNORE_ARGS[@]}" \) -prune \) -o -not -path '*/.*' -print
        fi
    fi

    echo -e "\n=== SOURCE CODE ===\n"

    if [ "$ONLY_CHANGED" -eq 1 ]; then
        git ls-files -m -o --exclude-standard | grep -Ev "$TREE_IGNORE"
    else
        find "${TARGETS[@]}" \( \( "${FIND_IGNORE_ARGS[@]}" \) -prune \) -o -type f -not -path '*/.*' -exec grep -Iq . {} \; -print
    fi | while read -r file; do

        # Финальный заслон
        for ignore in "${IGNORE_LIST[@]}"; do
            if [[ "$file" == *"$ignore"* ]]; then
                continue 2
            fi
        done

        echo -e "\e[32m  ->\e[0m Обработка: $file" >&2
        echo "FILE: $file"
        echo '```'
        [ "$MINIFY" -eq 1 ] && sed '/^$/d' "$file" || cat "$file"
        echo '```'
        echo -e "\n"
    done
} | $COPY_CMD

echo -e "\e[1;34m::\e[0m \e[32mГотово.\e[0m"