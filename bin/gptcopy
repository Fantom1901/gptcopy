#!/usr/bin/env bash

# Настройки исключений (папки разделены через -o -name)
IGNORE_DIRS="( -name node_modules -o -name venv -o -name .git -o -name .idea -o -name .vscode -o -name __pycache__ -o -name target -o -name dist -o -name build -o -name .next -o -name .astro -o -name .cache )"
# Для tree оставим старый формат
TREE_IGNORE="node_modules|venv|.git|.idea|.vscode|__pycache__|target|dist|build|.next|.astro|.cache"

show_help() {
    echo -e "\e[1;34mУТИЛИТА:\e[0m gptcopy v3.0"
    echo -e "\e[1;34mОПИСАНИЕ:\e[0m Собирает структуру проекта и содержимое файлов в один блок для LLM."
    echo -e "\n\e[1;34mИСПОЛЬЗОВАНИЕ:\e[0m"
    echo "  gptcopy [путь] [опции]"
    echo -e "\n\e[1;34mОПЦИИ:\e[0m"
    echo "  -c, --changed   Копировать только измененные файлы (через git status)"
    echo "  -m, --minify    Удалить пустые строки из кода (экономия места)"
    echo "  -h, --help      Показать эту справку"
    echo -e "\n\e[1;34mПРИМЕРЫ:\e[0m"
    echo "  gptcopy .             # Весь текущий каталог"
    echo "  gptcopy src/ -m       # Папка src с минификацией"
    echo "  gptcopy -c            # Только то, что ты сейчас правишь"
}

get_copy_cmd() {
    if [[ "$TERM" == "xterm-kitty" ]] && command -v kitten >/dev/null 2>&1; then
        echo "kitten clipboard"
    elif command -v wl-copy >/dev/null 2>&1; then
        echo "wl-copy"
    elif command -v xclip >/dev/null 2>&1; then
        echo "xclip -selection clipboard"
    else
        echo "cat"
    fi
}

ONLY_CHANGED=0
MINIFY=0
TARGETS=()

for arg in "$@"; do
    case $arg in
        -h|--help) show_help; exit 0 ;;
        -c|--changed) ONLY_CHANGED=1 ;;
        -m|--minify) MINIFY=1 ;;
        *) TARGETS+=("$arg") ;;
    esac
done

[[ ${#TARGETS[@]} -eq 0 ]] && TARGETS+=(".")
COPY_CMD=$(get_copy_cmd)

{
    echo "=== PROJECT STRUCTURE ==="
    if [ "$ONLY_CHANGED" -eq 1 ]; then
        git status -s 2>/dev/null || echo "Git не инициализирован."
    else
        if command -v tree >/dev/null 2>&1; then
            tree -a -I "$TREE_IGNORE" "${TARGETS[0]}"
        else
            find "${TARGETS[0]}" -maxdepth 2 -not -path '*/.*'
        fi
    fi
    echo -e "\n=== SOURCE CODE ===\n"

    if [ "$ONLY_CHANGED" -eq 1 ]; then
        FILES=$(git ls-files -m -o --exclude-standard)
    else
        # Используем -prune, чтобы find ВООБЩЕ не заходил в node_modules
        FILES=$(find "${TARGETS[@]}" $IGNORE_DIRS -prune -o -type f -not -path '*/.*' -exec grep -Iq . {} \; -print)
    fi

    for file in $FILES; do
        echo -e "\e[32m  ->\e[0m Обработка: $file" >&2
        echo "FILE: $file"
        echo '```'
        if [ "$MINIFY" -eq 1 ]; then
            sed '/^$/d' "$file"
        else
            cat "$file"
        fi
        echo '```'
        echo -e "\n"
    done
} | $COPY_CMD

echo -e "\e[1;34m::\e[0m \e[32mГотово.\e[0m Данные в буфере обмена."